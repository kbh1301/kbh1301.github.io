{
	"name": "kbh-portfolio",
	"version": "0.0.1",
	"private": true,
	"packageManager": "pnpm@11.1.3",
	"scripts": {
		"dev": "vite dev --host",
		"generate:pdf": "pnpm build && docker compose run --rm generate-pdf",
		"shadcn:add": "pnpm exec shadcn-svelte@0.14 add",
		"build": "vite build",
		"deploy": "pnpm build && pnpm exec gh-pages -d build -t true",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@iconify/svelte": "^4.0.2",
		"@sveltejs/adapter-auto": "^3.0.0",
		"@sveltejs/kit": "^2.0.0",
		"@sveltejs/vite-plugin-svelte": "^4.0.4",
		"@tailwindcss/typography": "^0.5.13",
		"autoprefixer": "^10.4.19",
		"bits-ui": "^0.22.0",
		"gh-pages": "^6.1.1",
		"playwright": "1.52.0",
		"postcss": "^8.4.38",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"tailwindcss": "^3.4.4",
		"typescript": "^5.0.0",
		"vite": "^5.0.3"
	},
	"type": "module",
	"dependencies": {
		"@sveltejs/adapter-static": "^3.0.2",
		"clsx": "^2.1.1",
		"embla-carousel-svelte": "^8.1.8",
		"lucide-svelte": "^0.419.0",
		"photoswipe": "^5.4.4",
		"tailwind-merge": "^2.4.0",
		"tailwind-variants": "^0.2.1"
	}
}
